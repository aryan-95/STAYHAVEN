# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017/stayhaven
# Atlas (replace with your own):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/stayhaven

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=30d

# ─── Client URL (CORS) ────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Public API URL (used for local image upload URLs) ────────────────────────
API_URL=http://localhost:5000

# ─── Cloudinary (optional – only needed if you switch to Cloudinary uploads) ──
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
